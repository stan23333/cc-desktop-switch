{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CC Desktop Switch",
  "version": "1.1.1",
  "identifier": "io.github.lonr6.ccdesktopswitch",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:4173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "CC Desktop Switch",
        "url": "ccds://localhost/",
        "width": 1240,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Claude Desktop provider switcher",
    "longDescription": "A desktop utility for configuring third-party Claude Desktop providers.",
    "icon": [
      "icons/icon.png",
      "../macos/assets/app-icon.icns",
      "../frontend/assets/app-icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
